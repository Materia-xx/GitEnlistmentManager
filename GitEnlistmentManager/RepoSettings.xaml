<Window x:Class="GitEnlistmentManager.RepoSettings"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:GitEnlistmentManager"
        mc:Ignorable="d"
        Title="Repo Settings" Height="500" Width="650" Loaded="Window_Loaded">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="5"/>
            <ColumnDefinition Width="110"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="5"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
            <RowDefinition Height="Auto" MinHeight="25"/>
            <RowDefinition Height="*" MinHeight="80"/>
            <RowDefinition Height="10"/>
            <RowDefinition Height="25"/>
            <RowDefinition Height="5"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="1" Grid.Column="1">Platform</TextBlock>
        <TextBlock Grid.Row="3" Grid.Column="1">Name</TextBlock>
        <TextBlock Grid.Row="5" Grid.Column="1">Short Name</TextBlock>
        <TextBlock Grid.Row="7" Grid.Column="1">Clone URL</TextBlock>
        <TextBlock Grid.Row="9" Grid.Column="1">Commit User Name</TextBlock>
        <TextBlock Grid.Row="11" Grid.Column="1">Commit User Email</TextBlock>

        <ComboBox Grid.Row="1" Grid.Column="2" x:Name="cboGitHostingPlatformName"/>
        <TextBox Grid.Row="3" Grid.Column="2" x:Name="txtName"/>
        <TextBox Grid.Row="5" Grid.Column="2" x:Name="txtShortName"/>
        <TextBox Grid.Row="7" Grid.Column="2" x:Name="txtCloneUrl"/>
        <TextBox Grid.Row="9" Grid.Column="2" x:Name="txtUserName"/>
        <TextBox Grid.Row="11" Grid.Column="2" x:Name="txtUserEmail"/>

        <Grid Grid.Row="13" Grid.Column="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <TextBlock Grid.Row="0" Grid.Column="0" Text="Choose Defaults From..."/>
            <ComboBox Grid.Row="0" Grid.Column="1" x:Name="cboChooseDefaultsFrom" SelectionChanged="cboChooseDefaultsFrom_SelectedChanged"></ComboBox>
        </Grid>

        <TextBlock Grid.Row="15" Grid.Column="1" VerticalAlignment="Top" Margin="0,5,0,0">Target Branches</TextBlock>
        <DataGrid Grid.Row="15" Grid.RowSpan="2" Grid.Column="2" x:Name="dgBranches"
                  AutoGenerateColumns="False" CanUserAddRows="True" CanUserDeleteRows="True"
                  HeadersVisibility="Column" GridLinesVisibility="All"
                  Margin="0,0,0,5">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Branch From" Binding="{Binding BranchFrom}" Width="*"/>
                <DataGridTextColumn Header="Branch Prefix" Binding="{Binding BranchPrefix}" Width="*"/>
                <DataGridTextColumn Header="Folder Name" Binding="{Binding FolderName}" Width="*"/>
            </DataGrid.Columns>
        </DataGrid>

        <Button Grid.Row="18" Grid.Column="2" Width="55" Content="Save" HorizontalAlignment="Right" Click="ButtonSave_Click" />
    </Grid>
</Window>
